# Copy to .env and fill in real values. .env is gitignored — never commit it.
# This file documents variable NAMES only; it must never contain real secrets.

# --- Model provider selection -------------------------------------------------
# One of: anthropic | openrouter | claude-subscription | ollama | lmstudio
# Unset or blank defaults to "anthropic".
MODEL_PROVIDER=anthropic

# Credential required by the SELECTED provider (only the matching one is needed;
# the local providers ollama/lmstudio need no credential):
#   anthropic           -> ANTHROPIC_API_KEY
#   openrouter          -> OPENROUTER_API_KEY
#   claude-subscription -> CLAUDE_CODE_OAUTH_TOKEN  (from: claude setup-token)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Optional model tag/name (e.g. an ollama model like "qwen2.5:32b", or a
# specific Anthropic/OpenRouter model id). Falls back to a provider default.
MODEL_NAME=

# --- Local models (ollama / lmstudio) -----------------------------------------
# OpenAI-compatible endpoints; override only if not on the default host/port.
#   ollama   default: http://localhost:11434/v1
#   lmstudio default: http://localhost:1234/v1
OLLAMA_BASE_URL=
LMSTUDIO_BASE_URL=

# Structured output: ollama/lmstudio/openrouter use native json_schema
# structured output when the MODEL supports it (the model is constrained to
# emit a valid ScheduleProposal), else the agent falls back to a
# validate-and-repair loop automatically. Support is per-model:
#   - LM Studio: models tagged with a "tool use" / structured-output badge
#     (most recent GGUFs — Qwen2.5, Llama-3.1/3.2, Mistral, Hermes, etc.).
#   - ollama: models with tool/structured-output support (llama3.1/3.2,
#     qwen2.5, mistral-nemo, firefunction, command-r, ...). Older/base models
#     may not — they'll use the repair loop.
# If you see a 400 about response_format/json_schema, the model or server
# version doesn't support it; pick a structured-output-capable model.

# --- WebCalendar MCP backend (used from Phase 1/2) ----------------------------
# Live-calendar endpoint + token. Keep these out of version control.
MCP_URL=
MCP_TOKEN=

# --- Observability (used from Phase 4) ----------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
LANGSMITH_PROJECT=
